{
  "name": "dream-builder",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @dream-builder/web",
    "dev:web": "npm run dev --workspace @dream-builder/web",
    "dev:mobile": "npm run start --workspace @dream-builder/mobile",
    "build": "npm run build --workspace @dream-builder/web",
    "build:web": "npm run build --workspace @dream-builder/web",
    "lint": "npm run lint --workspace @dream-builder/web"
  }
}
